# Production environment for Elfie backend on Linode VPS.
# Copy to `.env.prod` on the server and fill real values.
# NEVER commit this file.

# --- Database (prod) ---
# If using Linode Managed Postgres, set the full URL:
# ELFIE_DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:PORT/DB?sslmode=require
# If using the containerized db in docker-compose.prod.yml, leave these blank
# and set POSTGRES_* below — compose derives the URLs automatically.
POSTGRES_USER=elfie
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=elfie_labs

# --- Qwen (LLM) ---
ELFIE_QWEN_API_KEY=sk-replace-me
ELFIE_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ELFIE_QWEN_MODEL=qwen-turbo
ELFIE_QWEN_VL_MODEL=qwen3-vl-flash-2026-01-22

# --- Image beta lane (enables VLM PDF lane) ---
ELFIE_IMAGE_BETA_ENABLED=true

# --- File limits ---
ELFIE_MAX_UPLOAD_SIZE_MB=20
ELFIE_MAX_PDF_PAGES=30

# --- Supabase Auth (prod) ---
ELFIE_SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
ELFIE_SUPABASE_URL=https://your-project.supabase.co

# MUST be false in production.
ELFIE_DEV_AUTH_BYPASS=false

# --- CORS (prod Vercel origin) ---
ELFIE_CORS_ORIGINS=["https://elfie-lab-analyzer.vercel.app"]
ELFIE_CORS_ALLOW_CREDENTIALS=true

# --- Debug (never enable in production) ---
ELFIE_DEBUG=false
ELFIE_ALLOW_DEBUG_ARTIFACTS=false
