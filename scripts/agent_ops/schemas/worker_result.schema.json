{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Elfie worker result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "status",
    "summary",
    "changed_files",
    "commands_executed",
    "test_results",
    "evidence",
    "risks",
    "followups"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "worker-result-v1"
    },
    "task_id": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 5
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commands_executed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "exit_code",
          "purpose"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "exit_code": {
            "type": "integer"
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "output_summary": {
            "type": "string"
          }
        }
      }
    },
    "test_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "summary"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "diff",
              "test",
              "lint",
              "runtime",
              "note"
            ]
          },
          "path": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "followups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
