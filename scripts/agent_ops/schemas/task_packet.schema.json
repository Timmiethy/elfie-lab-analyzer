{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Elfie task packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "objective",
    "repo_root",
    "allowed_paths",
    "forbidden_paths",
    "required_commands",
    "required_tests",
    "completion_definition",
    "max_prompt_tokens",
    "max_tool_calls"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "task-packet-v1"
    },
    "task_id": {
      "type": "string",
      "minLength": 3
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_tests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "completion_definition": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "max_prompt_tokens": {
      "type": "integer",
      "minimum": 256,
      "maximum": 200000
    },
    "max_tool_calls": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "context_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
