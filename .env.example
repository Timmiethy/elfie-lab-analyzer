# ============================================================
# Elfie Lab Analyzer — Environment Variables
# ============================================================
# Copy to `.env` for local dev. For prod, set via Render/Vercel
# dashboards. Never commit real secrets.
# ============================================================

# --- Database (Render will provide its own URL; local uses docker) ---
ELFIE_DATABASE_URL=postgresql+asyncpg://elfie:elfie@localhost:5432/elfie_labs
ELFIE_DATABASE_URL_SYNC=postgresql://elfie:elfie@localhost:5432/elfie_labs

# --- Qwen API (LLM for extraction + cleaning) ---
ELFIE_QWEN_API_KEY=sk-REPLACE_ME
ELFIE_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Use qwen-turbo (fast) or qwen-plus (better quality, slower).
# Avoid qwen3.5-plus: reasoning model, too slow for batch cleaner.
ELFIE_QWEN_MODEL=qwen-turbo
ELFIE_QWEN_VL_MODEL=qwen3-vl-flash-2026-01-22

# --- Image beta lane (enables VLM PDF lane) ---
ELFIE_IMAGE_BETA_ENABLED=true

# --- File limits ---
ELFIE_MAX_UPLOAD_SIZE_MB=20
ELFIE_MAX_PDF_PAGES=30

# --- Supabase Auth ---
# Dashboard > Settings > API > JWT Secret (HS256 legacy) OR JWKS for asymmetric.
ELFIE_SUPABASE_JWT_SECRET=REPLACE_ME
ELFIE_SUPABASE_URL=https://REPLACE_ME.supabase.co

# Dev-only: bypass JWT validation → mock UUID. MUST be false in production.
ELFIE_DEV_AUTH_BYPASS=false

# --- CORS (prod: set to your Vercel domain) ---
# Comma-separated list of allowed origins.
ELFIE_CORS_ORIGINS=["http://localhost:5173"]
ELFIE_CORS_ALLOW_CREDENTIALS=true

# --- Debug (never enable in production) ---
ELFIE_DEBUG=false
ELFIE_ALLOW_DEBUG_ARTIFACTS=false
