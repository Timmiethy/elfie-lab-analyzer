# Database
ELFIE_DATABASE_URL=postgresql+asyncpg://elfie:elfie@localhost:5432/elfie_labs
ELFIE_DATABASE_URL_SYNC=postgresql://elfie:elfie@localhost:5432/elfie_labs

# Qwen API (explanation adapter)
ELFIE_QWEN_API_KEY=sk-
ELFIE_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ELFIE_QWEN_MODEL=qwen3.5-plus
ELFIE_QWEN_VL_MODEL=qwen3-vl-flash-2026-01-22

# Image beta lane
ELFIE_IMAGE_BETA_ENABLED=true

# File limits
ELFIE_MAX_UPLOAD_SIZE_MB=20
ELFIE_MAX_PDF_PAGES=30

# Supabase Auth (backend JWT validation)
# Get this from: Supabase Dashboard > Settings > API > JWT Secret
ELFIE_SUPABASE_JWT_SECRET=
# Project URL — used to fetch JWKS for verifying ES256/RS256 access tokens
# issued by Supabase's new asymmetric JWT signing keys.
ELFIE_SUPABASE_URL=