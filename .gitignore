# OS clutter
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Local environment and secrets
.env
.env.*
!.env.example
.venv/
venv/

# Python caches and build outputs
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
build/
dist/

# Frontend and Node build outputs
node_modules/
frontend/dist/
coverage/
*.tsbuildinfo

# Runtime logs
*.log
*.err
*.out
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local databases and service state
pgdata/
*.sqlite
*.sqlite3
*.db

# Agent scratch files
.claude/
.claw/
.clawd-todos.json
docs/orchestration/
scripts/orchestration/
pdfs_by_difficulty/

# Workflow scratch files
tasks/

# Local data sources that are not part of the committed corpus
data/loinc/*.csv
data/loinc/*.zip

# Generated data and runtime artifacts, while keeping directory placeholders
artifacts/*
!artifacts/.gitkeep
backend/artifacts/
backend/debug_loinc/

# Common local report/test inputs that should not be pushed
artifacts/**/*.png
artifacts/**/*.pdf
artifacts/**/*.html
artifacts/uploads/
artifacts/reports/
