# Frontend env template (Vercel Project Settings > Environment Variables)
# Copy to `.env.local` for local dev.

# Backend API base URL (no trailing slash). For local dev the Vite proxy
# handles `/api` -> http://localhost:8000, so leave this empty or unset.
VITE_API_URL=https://elfie-labs-backend.onrender.com

# Supabase client credentials
VITE_SUPABASE_URL=https://REPLACE_ME.supabase.co
VITE_SUPABASE_ANON_KEY=eyJREPLACE_ME
